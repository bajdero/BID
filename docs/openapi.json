{
  "openapi": "3.1.0",
  "info": {
    "title": "BID \u2014 Batch Image Delivery API",
    "description": "REST API for the **BID** (*Batch Image Delivery*) image-processing pipeline.\n\nBID automates batch photo processing: automatic scaling, watermark overlay, EXIF cleaning, colour-space conversion, and delivery-folder export.  This API exposes the processing core as an OpenAPI 3.0-compliant service, decoupled from the legacy Tkinter UI.\n\n## Road-map\n| Phase | Milestone | Status |\n|-------|-----------|--------|\n| 1 | Backend API Extraction | **In progress** |\n| 2 | WebSocket real-time layer | Planned |\n| 3 | React/TypeScript frontend | Planned |\n| 4 | Event system | Planned |\n\n## Auth\nPhase 1 includes a JWT-based auth layer. Protected endpoints require a valid Bearer token in the `Authorization` header.\n\n## Errors\nAll error responses use the `ErrorResponse` schema: `{ \"detail\": \"...\", \"field\": \"...\" }`.",
    "contact": {
      "name": "BID project",
      "url": "https://github.com/bajdero/BID"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Liveness probe",
        "description": "Return HTTP 200 with body ``{\"status\": \"ok\"}`` when the service is alive.",
        "operationId": "health_api_v1_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/version": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "API and BID version",
        "description": "Return the current API and BID product version strings.",
        "operationId": "version_api_v1_version_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/metrics/queue": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Processing-queue operational metrics",
        "description": "Return aggregate queue metrics across all projects:\n\n- **queue_length** \u2014 tasks waiting to start.\n- **active_workers** \u2014 tasks currently executing.\n- **max_workers** \u2014 concurrency ceiling (configured via `MAX_CONCURRENT_TASKS`).\n- **completed_total** / **failed_total** \u2014 counters since last process restart.\n- **utilization_pct** \u2014 `active_workers / max_workers \u00d7 100`.\n\nSuitable for monitoring dashboards and alerting rules.",
        "operationId": "queue_metrics_api_v1_metrics_queue_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueMetricsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects/{project_id}/process": {
      "post": {
        "tags": [
          "processing"
        ],
        "summary": "Enqueue selected photos for processing",
        "description": "Validate and enqueue the photos listed in *body.photos*.\nReturns immediately; processing runs in the background.",
        "operationId": "process_selected_api_v1_projects__project_id__process_post",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Project Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProcessRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request \u2014 path traversal or invalid input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Project or photo not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server-side processing error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects/{project_id}/process/all": {
      "post": {
        "tags": [
          "processing"
        ],
        "summary": "Enqueue all NEW photos in the project",
        "description": "Scan the project source_folder and enqueue every photo whose state is\n``new``, ``export_fail``, or ``error``.",
        "operationId": "process_all_api_v1_projects__project_id__process_all_post",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Project Id"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request \u2014 path traversal or invalid input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Project or photo not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server-side processing error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects/{project_id}/process/{folder}/{photo}": {
      "delete": {
        "tags": [
          "processing"
        ],
        "summary": "Reset a photo to NEW state (re-queue)",
        "description": "Reset the photo identified by *folder/photo* back to state ``new`` so it\nwill be picked up by the next ``process/all`` run.\n\nReturns HTTP 404 if the photo is not found in the source index.",
        "operationId": "reset_photo_api_v1_projects__project_id__process__folder___photo__delete",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Project Id"
            }
          },
          {
            "name": "folder",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Folder"
            }
          },
          {
            "name": "photo",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Photo"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Reset Photo Api V1 Projects  Project Id  Process  Folder   Photo  Delete"
                }
              }
            }
          },
          "400": {
            "description": "Bad request \u2014 path traversal or invalid input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Project or photo not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server-side processing error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects/{project_id}/process/status": {
      "get": {
        "tags": [
          "processing"
        ],
        "summary": "Current processing-queue status",
        "description": "Return a snapshot of the in-flight and completed task counters.",
        "operationId": "get_process_status_api_v1_projects__project_id__process_status_get",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Project Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessStatusResponse"
                }
              }
            }
          },
          "404": {
            "description": "Project not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects/{project_id}/exports/conflicts": {
      "get": {
        "tags": [
          "exports"
        ],
        "summary": "List blocked / missing export files",
        "description": "Return export entries where the expected output file is missing or has\nzero bytes on disk \u2014 indicating the photo needs to be re-processed.",
        "operationId": "list_conflicts_api_v1_projects__project_id__exports_conflicts_get",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Project Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ConflictItem"
                  },
                  "title": "Response List Conflicts Api V1 Projects  Project Id  Exports Conflicts Get"
                }
              }
            }
          },
          "404": {
            "description": "Project not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects/{project_id}/exports/conflicts/resolve": {
      "post": {
        "tags": [
          "exports"
        ],
        "summary": "Resolve export conflicts",
        "description": "Apply *body.action* to the matching conflict records.\n\n- ``action=\"replace\"`` resets state to ``new`` (re-queues for processing).\n- ``action=\"skip\"``    marks the photo as ``skip``.",
        "operationId": "resolve_conflicts_api_v1_projects__project_id__exports_conflicts_resolve_post",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Project Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConflictResolutionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Number of resolved conflicts and the action applied.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Resolve Conflicts Api V1 Projects  Project Id  Exports Conflicts Resolve Post"
                }
              }
            }
          },
          "404": {
            "description": "Project not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ConflictItem": {
        "properties": {
          "profile": {
            "type": "string",
            "title": "Profile"
          },
          "folder": {
            "type": "string",
            "title": "Folder"
          },
          "photo": {
            "type": "string",
            "title": "Photo"
          },
          "target_path": {
            "type": "string",
            "title": "Target Path"
          },
          "reason": {
            "type": "string",
            "title": "Reason",
            "default": "missing_or_empty"
          }
        },
        "type": "object",
        "required": [
          "profile",
          "folder",
          "photo",
          "target_path"
        ],
        "title": "ConflictItem",
        "description": "A single blocked / missing export entry.",
        "example": {
          "folder": "Session1",
          "photo": "IMG_001.jpg",
          "profile": "fb",
          "reason": "missing_or_empty",
          "target_path": "fb/Session1/YAPA2026-03-23_Session1_IMG_001.jpg"
        }
      },
      "ConflictResolutionRequest": {
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "all",
              "selection"
            ],
            "title": "Mode"
          },
          "action": {
            "type": "string",
            "enum": [
              "replace",
              "skip"
            ],
            "title": "Action"
          },
          "items": {
            "anyOf": [
              {
                "items": {
                  "prefixItems": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "string"
                    }
                  ],
                  "type": "array",
                  "maxItems": 2,
                  "minItems": 2
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "mode",
          "action"
        ],
        "title": "ConflictResolutionRequest",
        "description": "Request body for POST /exports/conflicts/resolve.\n\nmode:\n  \"all\"       \u2013 apply action to every conflict in the project.\n  \"selection\" \u2013 apply action to the photos listed in `items`.\n\naction:\n  \"replace\"  \u2013 reset state to \"new\" so the photo is re-queued.\n  \"skip\"     \u2013 mark the photo as \"skip\" (do not process again).",
        "example": {
          "action": "replace",
          "items": [
            [
              "Session1",
              "IMG_001.jpg"
            ],
            [
              "Session1",
              "IMG_002.jpg"
            ]
          ],
          "mode": "selection"
        }
      },
      "ErrorResponse": {
        "properties": {
          "detail": {
            "type": "string",
            "title": "Detail"
          },
          "field": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Field"
          }
        },
        "type": "object",
        "required": [
          "detail"
        ],
        "title": "ErrorResponse",
        "description": "Standard error envelope returned by exception handlers.",
        "example": {
          "detail": "Project 'my_project' not found."
        }
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "default": "ok"
          }
        },
        "type": "object",
        "title": "HealthResponse",
        "example": {
          "status": "ok"
        }
      },
      "PhotoTaskStatus": {
        "properties": {
          "folder": {
            "type": "string",
            "title": "Folder"
          },
          "photo": {
            "type": "string",
            "title": "Photo"
          },
          "state": {
            "type": "string",
            "enum": [
              "processing",
              "queued"
            ],
            "title": "State",
            "default": "processing"
          },
          "profile": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Profile"
          }
        },
        "type": "object",
        "required": [
          "folder",
          "photo"
        ],
        "title": "PhotoTaskStatus",
        "description": "Status snapshot of a single in-flight processing task.",
        "example": {
          "folder": "Session1",
          "photo": "IMG_001.jpg",
          "profile": "fb",
          "state": "processing"
        }
      },
      "ProcessRequest": {
        "properties": {
          "photos": {
            "items": {
              "prefixItems": [
                {
                  "type": "string"
                },
                {
                  "type": "string"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "minItems": 1,
            "title": "Photos",
            "description": "List of (folder, photo) pairs to process."
          },
          "profiles": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Profiles",
            "description": "Export profile keys to apply.  None = all profiles."
          }
        },
        "type": "object",
        "required": [
          "photos"
        ],
        "title": "ProcessRequest",
        "description": "Body for POST /projects/{id}/process.\n\nphotos: list of (folder, photo) tuples identifying the source photos to process.\nprofiles: optional allowlist of export profile keys.  None means all profiles.",
        "example": {
          "photos": [
            [
              "Session1",
              "IMG_001.jpg"
            ],
            [
              "Session1",
              "IMG_002.jpg"
            ]
          ],
          "profiles": [
            "fb",
            "print"
          ]
        }
      },
      "ProcessResponse": {
        "properties": {
          "task_id": {
            "type": "string",
            "title": "Task Id"
          },
          "queued": {
            "type": "integer",
            "title": "Queued"
          },
          "skipped": {
            "type": "integer",
            "title": "Skipped",
            "default": 0
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "task_id",
          "queued",
          "message"
        ],
        "title": "ProcessResponse",
        "description": "Returned immediately after photos are enqueued (non-blocking).",
        "example": {
          "message": "2 photo(s) enqueued for processing.",
          "queued": 2,
          "skipped": 0,
          "task_id": "a3f1b2c4-5d6e-7f8a-9b0c-1d2e3f4a5b6c"
        }
      },
      "ProcessStatusResponse": {
        "properties": {
          "queue_length": {
            "type": "integer",
            "title": "Queue Length"
          },
          "active": {
            "items": {
              "$ref": "#/components/schemas/PhotoTaskStatus"
            },
            "type": "array",
            "title": "Active"
          },
          "completed": {
            "type": "integer",
            "title": "Completed",
            "default": 0
          },
          "failed": {
            "type": "integer",
            "title": "Failed",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "queue_length",
          "active"
        ],
        "title": "ProcessStatusResponse",
        "description": "Current state of the processing queue for a project.",
        "example": {
          "active": [
            {
              "folder": "Session1",
              "photo": "IMG_001.jpg",
              "profile": "fb",
              "state": "processing"
            }
          ],
          "completed": 5,
          "failed": 0,
          "queue_length": 1
        }
      },
      "QueueMetricsResponse": {
        "properties": {
          "queue_length": {
            "type": "integer",
            "title": "Queue Length",
            "description": "Number of tasks currently waiting."
          },
          "active_workers": {
            "type": "integer",
            "title": "Active Workers",
            "description": "Tasks actively processing right now."
          },
          "max_workers": {
            "type": "integer",
            "title": "Max Workers",
            "description": "Configured concurrency ceiling."
          },
          "completed_total": {
            "type": "integer",
            "title": "Completed Total",
            "description": "Tasks completed since last restart."
          },
          "failed_total": {
            "type": "integer",
            "title": "Failed Total",
            "description": "Tasks that ended in error since last restart."
          },
          "utilization_pct": {
            "type": "number",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Utilization Pct",
            "description": "active_workers / max_workers \u00d7 100."
          }
        },
        "type": "object",
        "required": [
          "queue_length",
          "active_workers",
          "max_workers",
          "completed_total",
          "failed_total",
          "utilization_pct"
        ],
        "title": "QueueMetricsResponse",
        "description": "Operational metrics for the processing queue.",
        "example": {
          "active_workers": 2,
          "completed_total": 142,
          "failed_total": 1,
          "max_workers": 5,
          "queue_length": 3,
          "utilization_pct": 40.0
        }
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
